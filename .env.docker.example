# omb-accounting Docker Environment Configuration
# Copy this file to .env.docker and update values

# Application
NODE_ENV=production
PORT=3000
NEXT_PUBLIC_APP_VERSION=0.1.0

# Database
DATABASE_PATH=/app/data/omb-accounting.db

# Authentication
# IMPORTANT: Change this to a secure random string in production!
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Session
SESSION_TIMEOUT=1800  # 30 minutes in seconds

# Initialization Mode
# empty = Create database with admin user only
# seed = Create database with sample data
INIT_MODE=empty

# Admin User (for empty initialization)
ADMIN_EMAIL=admin@omb.com
ADMIN_PASSWORD=admin123

# Logging
LOG_LEVEL=info
LOG_FILE=/app/logs/app.log

# Security
# CORS_ORIGIN=http://your-domain.com
# RATE_LIMIT_MAX=100
# RATE_LIMIT_WINDOW=60000
